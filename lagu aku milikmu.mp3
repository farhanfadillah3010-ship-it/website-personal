    <!-- MUSIC PLAYER -->
    <div class="music-player">
        <button class="music-btn" id="play-pause" onclick="toggleMusic()">▶</button>
        <div style="display: flex; flex-direction: column;">
            <span style="font-size: 11px; color: #888;">Now Playing</span>
            <span style="font-size: 13px; font-weight: bold;">Aku Milikmu - Dewa 19</span>
        </div>
        <!-- Nama file di src harus SAMA PERSIS dengan nama file yang kamu upload ke GitHub -->
        <audio id="myAudio" loop>
            <source src="akumilikmu.mp3" type="audio/mpeg">
        </audio>
    </div>
